{
  "schema_version": 1,
  "service_slug": "agentmail-to",
  "notes": "Native API signup: POST /v0/agent/sign-up returns api_key + inbox_id. Persistence proven by GET /v0/inboxes with bearer. Workflow sends email to pre-allowed human_email (sudo@pressclub.app) and lists inbox to confirm it's operational.",
  "allowed_env": [],
  "sandbox": {
    "url_allowlist": ["api.agentmail.to"]
  },
  "tests": {
    "signup": {
      "produces": ["agentmail_api_key", "agentmail_inbox_id"],
      "agent_task": {
        "prompt": "Sign up for AgentMail autonomously. AgentMail is a programmable email-inbox service for AI agents. Its documentation is at https://docs.agentmail.to. The signup endpoint is POST https://api.agentmail.to/v0/agent/sign-up with a JSON body containing:\n  - human_email: a human contact email. Use \"sudo@pressclub.app\" (this address is pre-allowed).\n  - username: a unique username prefixed with \"onlybots-test-\" followed by a random suffix to avoid collisions.\n\nThe response is a JSON object with \"api_key\", \"organization_id\", and \"inbox_id\" fields. Execute the signup (use curl or any HTTP client available to you), then report the credentials.",
        "expected_artifacts": ["agentmail_api_key", "agentmail_inbox_id"],
        "model": "gemini-2.5-flash",
        "timeout_s": 180
      },
      "steps": [
        {
          "kind": "http",
          "id": "probe_auth",
          "method": "GET",
          "url": "https://api.agentmail.to/v0/inboxes",
          "headers": {"Authorization": "Bearer {agentmail_api_key}"},
          "description": "Verifier probe: does the agent-reported api_key actually work?"
        }
      ],
      "assertions": [
        {"kind": "artifact_present", "artifact": "agentmail_api_key",
         "description": "agent reported an api_key"},
        {"kind": "artifact_present", "artifact": "agentmail_inbox_id",
         "description": "agent reported an inbox_id"},
        {"kind": "http_status_ok", "step": "probe_auth",
         "description": "agent-reported api_key is real (not hallucinated)"}
      ]
    },
    "persistence": {
      "requires": ["agentmail_api_key"],
      "steps": [
        {
          "kind": "http",
          "id": "list_inboxes",
          "method": "GET",
          "url": "https://api.agentmail.to/v0/inboxes",
          "headers": {"Authorization": "Bearer {agentmail_api_key}"},
          "description": "GET /v0/inboxes with bearer"
        }
      ],
      "assertions": [
        {"kind": "http_status_ok", "step": "list_inboxes",
         "description": "credential still valid"}
      ]
    },
    "workflow": {
      "requires": ["agentmail_api_key", "agentmail_inbox_id"],
      "steps": [
        {
          "kind": "http",
          "id": "send_email",
          "method": "POST",
          "url": "https://api.agentmail.to/v0/inboxes/{agentmail_inbox_id}/messages/send",
          "headers": {"Authorization": "Bearer {agentmail_api_key}"},
          "body_json": {
            "to": ["sudo@pressclub.app"],
            "subject": "OnlyBots Verification Test",
            "body": "This is an automated test by OnlyBots trust registry."
          },
          "description": "POST /v0/inboxes/{inbox_id}/messages/send"
        },
        {
          "kind": "http",
          "id": "list_messages",
          "method": "GET",
          "url": "https://api.agentmail.to/v0/inboxes/{agentmail_inbox_id}/messages",
          "headers": {"Authorization": "Bearer {agentmail_api_key}"},
          "description": "GET /v0/inboxes/{inbox_id}/messages"
        }
      ],
      "assertions": [
        {"kind": "http_status_ok", "step": "send_email"},
        {"kind": "http_status_ok", "step": "list_messages"}
      ]
    }
  }
}
