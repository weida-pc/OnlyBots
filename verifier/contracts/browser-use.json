{
  "schema_version": 1,
  "service_slug": "browser-use",
  "notes": "Browser Use has no programmatic signup (requires domain email). The verifier uses a pre-provisioned BROWSER_USE_API_KEY from env and the non-standard X-Browser-Use-API-Key auth header. Intentionally NOT migrated to agent-driven signup for the same reason as signbee: the agent would add LLM cost + latency to a one-call auth probe with zero autonomy signal. Direct-HTTP is the honest representation.",
  "allowed_env": ["BROWSER_USE_API_KEY"],
  "sandbox": {
    "url_allowlist": ["api.browser-use.com"]
  },
  "tests": {
    "signup": {
      "produces": ["browseruse_api_key"],
      "steps": [
        {
          "kind": "env_secret",
          "id": "load_key",
          "env_var": "BROWSER_USE_API_KEY",
          "state_key": "browseruse_api_key",
          "required": true
        },
        {
          "kind": "http",
          "id": "list_sessions",
          "method": "GET",
          "url": "https://api.browser-use.com/api/v3/sessions",
          "headers": {"X-Browser-Use-API-Key": "{browseruse_api_key}"},
          "extract": {
            "browseruse_session_count": "total"
          },
          "description": "GET /api/v3/sessions (auth probe)"
        }
      ],
      "assertions": [
        {"kind": "http_status_ok", "step": "list_sessions",
         "description": "credential accepted at signup"}
      ]
    },
    "persistence": {
      "requires": ["browseruse_api_key"],
      "steps": [
        {
          "kind": "http",
          "id": "list_sessions_again",
          "method": "GET",
          "url": "https://api.browser-use.com/api/v3/sessions",
          "headers": {"X-Browser-Use-API-Key": "{browseruse_api_key}"},
          "description": "GET /api/v3/sessions (re-auth probe)"
        }
      ],
      "assertions": [
        {"kind": "http_status_ok", "step": "list_sessions_again",
         "description": "credential still valid"}
      ]
    },
    "workflow": {
      "requires": ["browseruse_api_key"],
      "produces": ["browseruse_session_id"],
      "steps": [
        {
          "kind": "http",
          "id": "create_session",
          "method": "POST",
          "url": "https://api.browser-use.com/api/v3/sessions",
          "headers": {"X-Browser-Use-API-Key": "{browseruse_api_key}"},
          "body_json": {
            "task": "Navigate to https://example.com and return the page title"
          },
          "extract": {
            "browseruse_session_id": "id || session_id"
          },
          "description": "POST /api/v3/sessions (create automation task)"
        },
        {
          "kind": "http",
          "id": "check_session",
          "method": "GET",
          "url": "https://api.browser-use.com/api/v3/sessions/{browseruse_session_id}",
          "headers": {"X-Browser-Use-API-Key": "{browseruse_api_key}"},
          "description": "GET /api/v3/sessions/{id} (verify task started)"
        }
      ],
      "assertions": [
        {"kind": "http_status_ok", "step": "create_session"},
        {"kind": "artifact_present", "artifact": "browseruse_session_id"},
        {"kind": "http_status_ok", "step": "check_session"}
      ]
    }
  }
}
