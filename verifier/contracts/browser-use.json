{
  "schema_version": 1,
  "service_slug": "browser-use",
  "notes": "Uses pre-provisioned BROWSER_USE_API_KEY (no programmatic signup — requires domain email). Uses non-standard X-Browser-Use-API-Key header instead of Authorization Bearer. Workflow creates a browser automation task.",
  "allowed_env": ["BROWSER_USE_API_KEY"],
  "sandbox": {
    "url_allowlist": ["api.browser-use.com"]
  },
  "tests": {
    "signup": {
      "produces": ["browseruse_api_key", "browseruse_session_count"],
      "agent_task": {
        "prompt": "Exercise the Browser Use API autonomously. Browser Use is a browser-automation-as-a-service platform. There is no programmatic signup (requires domain email), so the verifier pre-provisions an API key:\n\n    BROWSER_USE_API_KEY = {browseruse_api_key}\n\nIMPORTANT: Browser Use uses a non-standard auth header. You must send:\n\n    X-Browser-Use-API-Key: <api_key>\n\nNOT Authorization: Bearer.\n\nCall GET https://api.browser-use.com/api/v3/sessions to confirm the credential works. The response is a JSON object with a \"total\" field. Capture that field's value and report it along with the API key.",
        "expected_artifacts": ["browseruse_session_count"],
        "model": "gemini-2.5-flash",
        "timeout_s": 120
      },
      "steps": [
        {
          "kind": "env_secret",
          "id": "load_key",
          "env_var": "BROWSER_USE_API_KEY",
          "state_key": "browseruse_api_key",
          "required": true,
          "description": "Load BROWSER_USE_API_KEY so the agent prompt can reference it"
        },
        {
          "kind": "http",
          "id": "probe_auth",
          "method": "GET",
          "url": "https://api.browser-use.com/api/v3/sessions",
          "headers": {"X-Browser-Use-API-Key": "{browseruse_api_key}"},
          "description": "Verifier probe: does the key the agent used actually work?"
        }
      ],
      "assertions": [
        {"kind": "artifact_present", "artifact": "browseruse_api_key"},
        {"kind": "http_status_ok", "step": "probe_auth",
         "description": "credential agent claimed to use actually authenticates"}
      ]
    },
    "persistence": {
      "requires": ["browseruse_api_key"],
      "steps": [
        {
          "kind": "http",
          "id": "list_sessions_again",
          "method": "GET",
          "url": "https://api.browser-use.com/api/v3/sessions",
          "headers": {"X-Browser-Use-API-Key": "{browseruse_api_key}"},
          "description": "GET /api/v3/sessions (re-auth probe)"
        }
      ],
      "assertions": [
        {"kind": "http_status_ok", "step": "list_sessions_again",
         "description": "credential still valid"}
      ]
    },
    "workflow": {
      "requires": ["browseruse_api_key"],
      "produces": ["browseruse_session_id"],
      "steps": [
        {
          "kind": "http",
          "id": "create_session",
          "method": "POST",
          "url": "https://api.browser-use.com/api/v3/sessions",
          "headers": {"X-Browser-Use-API-Key": "{browseruse_api_key}"},
          "body_json": {
            "task": "Navigate to https://example.com and return the page title"
          },
          "extract": {
            "browseruse_session_id": "id || session_id"
          },
          "description": "POST /api/v3/sessions (create automation task)"
        },
        {
          "kind": "http",
          "id": "check_session",
          "method": "GET",
          "url": "https://api.browser-use.com/api/v3/sessions/{browseruse_session_id}",
          "headers": {"X-Browser-Use-API-Key": "{browseruse_api_key}"},
          "description": "GET /api/v3/sessions/{id} (verify task started)"
        }
      ],
      "assertions": [
        {"kind": "http_status_ok", "step": "create_session"},
        {"kind": "artifact_present", "artifact": "browseruse_session_id"},
        {"kind": "http_status_ok", "step": "check_session"}
      ]
    }
  }
}
