{
  "schema_version": 1,
  "service_slug": "signbee",
  "notes": "Signbee has no programmatic signup — sender identity requires email OTP. The verifier uses a pre-provisioned SIGNBEE_API_KEY from env. Intentionally NOT migrated to agent-driven signup: the agent would be given the key and told to make one POST, adding Gemini token cost and ~10s latency for zero autonomy signal. Direct-HTTP is the honest representation of what autonomy this service supports (i.e., none at signup).",
  "allowed_env": ["SIGNBEE_API_KEY"],
  "sandbox": {
    "url_allowlist": ["signb.ee"]
  },
  "tests": {
    "signup": {
      "produces": ["signbee_api_key", "signbee_document_id"],
      "steps": [
        {
          "kind": "env_secret",
          "id": "load_key",
          "env_var": "SIGNBEE_API_KEY",
          "state_key": "signbee_api_key",
          "required": true
        },
        {
          "kind": "http",
          "id": "send",
          "method": "POST",
          "url": "https://signb.ee/api/v1/send",
          "headers": {"Authorization": "Bearer {signbee_api_key}"},
          "body_json": {
            "recipient_name": "OnlyBots Verifier",
            "recipient_email": "sudo@pressclub.app",
            "markdown": "# OnlyBots Verification Document\n\nThis document verifies that Signbee supports autonomous document workflows for AI agents registered in the OnlyBots trust registry.\n\n## Scope\n\nThis is an automated verification-only test document."
          },
          "extract": {
            "signbee_document_id": "document_id || id"
          },
          "description": "POST /api/v1/send"
        }
      ],
      "assertions": [
        {"kind": "http_status_ok", "step": "send"},
        {"kind": "artifact_present", "artifact": "signbee_document_id"}
      ]
    },
    "persistence": {
      "requires": ["signbee_api_key"],
      "steps": [
        {
          "kind": "http",
          "id": "send_again",
          "method": "POST",
          "url": "https://signb.ee/api/v1/send",
          "headers": {"Authorization": "Bearer {signbee_api_key}"},
          "body_json": {
            "recipient_name": "OnlyBots Persistence Check",
            "recipient_email": "sudo@pressclub.app",
            "markdown": "# Persistence Check\n\nVerifying API key still works after initial signup."
          },
          "description": "POST /api/v1/send (2nd — verify key still works)"
        }
      ],
      "assertions": [
        {"kind": "http_status_ok", "step": "send_again",
         "description": "credential still valid"}
      ]
    },
    "workflow": {
      "requires": ["signbee_api_key"],
      "produces": ["signbee_workflow_doc_id"],
      "steps": [
        {
          "kind": "http",
          "id": "send_workflow",
          "method": "POST",
          "url": "https://signb.ee/api/v1/send",
          "headers": {"Authorization": "Bearer {signbee_api_key}"},
          "body_json": {
            "recipient_name": "OnlyBots Workflow Check",
            "recipient_email": "sudo@pressclub.app",
            "markdown": "# OnlyBots Workflow Check\n\nEnd-to-end workflow verification: send document via Signbee API."
          },
          "extract": {
            "signbee_workflow_doc_id": "document_id || id"
          },
          "description": "POST /api/v1/send (workflow)"
        }
      ],
      "assertions": [
        {"kind": "http_status_ok", "step": "send_workflow"},
        {"kind": "artifact_present", "artifact": "signbee_workflow_doc_id"}
      ]
    }
  }
}
